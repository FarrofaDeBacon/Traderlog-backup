use crate::db::DbState;
use crate::models::{
    UserProfile, Account, Currency, Market, AssetType, Asset, EmotionalState, Strategy, ApiConfig,
    Trade, CashTransaction, JournalEntry, FeeProfile, RiskProfile, Modality, Tag, Indicator,
    Timeframe, ChartType
};
use tauri::State;

// --- User Profile & Settings ---

#[tauri::command]
pub async fn get_user_profile(db: State<'_, DbState>) -> Result<Option<UserProfile>, String> {
    let profile: Option<UserProfile> = db.0.select(("user_profile", "main")).await.map_err(|e| e.to_string())?;
    Ok(profile)
}

#[tauri::command]
pub async fn save_user_profile(db: State<'_, DbState>, profile: UserProfile) -> Result<(), String> {
    let _: Option<UserProfile> = db.0.upsert(("user_profile", "main")).content(profile).await.map_err(|e| e.to_string())?;
    Ok(())
}

#[tauri::command]
pub async fn get_api_configs(db: State<'_, DbState>) -> Result<Vec<ApiConfig>, String> {
    let configs: Vec<ApiConfig> = db.0.select("api_config").await.map_err(|e| e.to_string())?;
    Ok(configs)
}

#[tauri::command]
pub async fn save_api_config(db: State<'_, DbState>, config: ApiConfig) -> Result<(), String> {
    let _: Option<ApiConfig> = db.0.upsert(("api_config", config.id.clone())).content(config).await.map_err(|e| e.to_string())?;
    Ok(())
}

